# ── AI Chat Interface Configuration ──

# Path to the initial OpenVINO model directory loaded at startup
MODEL_PATH=../models/phi-4-mini-instruct-int8-ov/

# Inference device: AUTO (tries GPU then falls back to CPU), GPU, or CPU
# Use AUTO for systems with limited GPU VRAM (< 2GB)
DEVICE=AUTO

# Maximum number of new tokens the model generates per response
MAX_NEW_TOKENS=2048

# Maximum conversation history length (number of messages to keep)
MAX_HISTORY=10

# Maximum input tokens (controls context window size, supports up to 128000/128k)
# Lower this if you get GPU memory errors
MAX_INPUT_TOKENS=1024

# Generation timeout in seconds (kills stuck generation threads)
GENERATION_TIMEOUT=120

# ── OpenVINO & KV-Cache Settings ──
# Whether to use KV-cache optimization during generation (True/False)
USE_CACHE=True

# Custom model file name in MODEL_PATH (leave blank to default to openvino_model.xml)
# MODEL_FILE_NAME=openvino_model.xml

# Tokenizer options
TRUST_REMOTE_CODE=True
FIX_MISTRAL_REGEX=True

# OpenVINO configuration parameters
# Performance Hint: LATENCY, THROUGHPUT, or CUMULATIVE_THROUGHPUT
OV_PERFORMANCE_HINT=LATENCY

# Whether to enable large memory allocations on Intel GPU (True/False)
# Set to True to prevent GPU driver allocation crashes with context windows > 1024 tokens
OV_GPU_ENABLE_LARGE_ALLOCATIONS=True

# Full custom OpenVINO configuration as a JSON string (takes precedence over performance hint)
# OV_CONFIG={"PERFORMANCE_HINT": "LATENCY"}

# OpenVINO KV cache precision optimization (u8, f16, or DEFAULT)
# Set to u8 (default) to compress key-value tokens, reducing memory usage by 50%
# Set to DEFAULT to use the model/OpenVINO runtime default precision (typically f16)
OV_KV_CACHE_PRECISION=u8

# Force Low VRAM mode to optimize memory usage (True/False)
# Compresses the KV cache to 8-bit (u8), disables driver-level reorder caching, and optimizes compute hints.
FORCE_LOW_VRAM_MODE=False

# Hard limit for input token sequences right before GPU execution (Foolproof OOM Guardrail).
# Slices the raw tokenized tensor if it exceeds this value (keeps only the newest tokens).
# Can be set higher than MAX_INPUT_TOKENS to allow large single prompts while keeping standard history short.
MAX_TOKEN_LIMIT=4096


# Flask server host and port
HOST=0.0.0.0
PORT=5000

